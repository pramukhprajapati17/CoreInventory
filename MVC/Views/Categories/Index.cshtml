@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-3">Product Categories</h2>
<div id="grid"></div>

@section Scripts {
    <link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.common.min.css" />
    <link rel="stylesheet" href="https://kendo.cdn.telerik.com/2021.2.616/styles/kendo.default.min.css" />
    <script src="https://kendo.cdn.telerik.com/2021.2.616/js/kendo.all.min.js"></script>
    <script>
        $(document).ready(function () {
            function toCamel(item) {
                return {
                    categoryId: item.CategoryId,
                    categoryName: item.CategoryName,
                    categoryCode: item.CategoryCode
                };
            }

            var dataSource = new kendo.data.DataSource({
                transport: {
                    read: { url: "/api/categories", type: "GET", dataType: "json" },
                    create: { url: "/api/categories", type: "POST", contentType: "application/json", dataType: "json" },
                    update: {
                        url: function (data) { return "/api/categories/" + data.categoryId; },
                        type: "PUT",
                        contentType: "application/json",
                        dataType: "json"
                    },
                    destroy: {
                        url: function (data) { return "/api/categories/" + data.categoryId; },
                        type: "DELETE",
                        dataType: "json"
                    },
                    parameterMap: function (data, type) {
                        function asNumber(value) {
                            var n = Number(value);
                            return Number.isFinite(n) ? n : null;
                        }

                        if (type === "create" || type === "update") {
                            var payload = {
                                CategoryId: asNumber(data.categoryId),
                                CategoryName: data.categoryName,
                                CategoryCode: data.categoryCode
                            };
                            if (type === "create") {
                                delete payload.CategoryId;
                            }
                            return kendo.stringify(payload);
                        }
                        if (type === "destroy") {
                            return kendo.stringify({ CategoryId: data.categoryId });
                        }
                        return data;
                    }
                },
                pageSize: 10,
                schema: {
                    data: function (response) {
                        if (response && response.length && response[0].CategoryId !== undefined) {
                            return response.map(toCamel);
                        }
                        return response;
                    },
                    model: {
                        id: "categoryId",
                        fields: {
                            categoryId: { type: "number", editable: false, nullable: true },
                            categoryName: { type: "string", validation: { required: true } },
                            categoryCode: { type: "string", validation: { required: true } }
                        }
                    }
                }
            });

            $("#grid").kendoGrid({
                dataSource: dataSource,
                columns: [
                    { field: "categoryId", title: "ID", width: 80 },
                    { field: "categoryName", title: "Name" },
                    { field: "categoryCode", title: "Code" },
                    { command: ["edit", "destroy"], title: "Actions", width: "200px" }
                ],
                editable: "popup",
                toolbar: ["create"],
                pageable: true,
                sortable: true,
                filterable: true,
                edit: function (e) {
                    var popup = e.container.data("kendoWindow");
                    var updateButton = e.container.find(".k-grid-update");
                    var isNew = e.model.isNew();
                    if (isNew) {
                        popup.title("Create Category");
                        updateButton.text("Add Category");
                    } else {
                        popup.title("Edit Category");
                        updateButton.text("Update Category");
                    }
                }
            });

            dataSource.bind("error", function (e) {
                var message = e.xhr && e.xhr.responseJSON && e.xhr.responseJSON.message
                    ? e.xhr.responseJSON.message
                    : "Operation failed.";
                Swal.fire({ icon: "error", title: "Error", text: message });
            });

            dataSource.bind("requestEnd", function (e) {
                if ((e.type === "create" || e.type === "update" || e.type === "destroy") && e.response) {
                    Swal.fire({
                        toast: true,
                        position: "top-end",
                        icon: "success",
                        title: "Saved",
                        showConfirmButton: false,
                        timer: 1200,
                        width: 280
                    });
                }
            });
        });
    </script>
}
