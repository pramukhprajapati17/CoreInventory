<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="app-brand">
            <a asp-area="" asp-controller="Home" asp-action="Index">CoreInventory</a>
        </div>
        <div class="app-actions">
            @if (Context.Session.TryGetValue("c_user_id", out _))
            {
                <a class="btn btn-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            }
            else
            {
                <a class="btn btn-link text-light" asp-controller="Account" asp-action="Login">Login</a>
                <a class="btn btn-warning btn-sm" asp-controller="Account" asp-action="Signup">Sign Up</a>
            }
        </div>
    </header>

    <main role="main" class="app-main">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div>
            &copy; 2026 - CoreInventory
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
